         </item>
         <item row="1" column="0">
          <widget class="QLabel" name="perplexityLabel">
           <property name="text">
            <string>Perplexity:</string>
           </property>
           <property name="toolTip">
            <string>Effective number of neighbors (typical range 5–50)</string>
           </property>
          </widget>
         </item>
         <item row="1" column="1">
          <widget class="QDoubleSpinBox" name="perplexitySpinBox">
           <property name="toolTip">
            <string>Controls the balance between local and global structure. Higher values consider more neighbors.</string>
           </property>
           <property name="minimum">
            <double>1.000000000000000</double>
           </property>
           <property name="maximum">
            <double>200.000000000000000</double>
           </property>
           <property name="singleStep">
            <double>5.000000000000000</double>
           </property>
           <property name="value">
            <double>30.000000000000000</double>
           </property>
          </widget>
         </item>
         <item row="2" column="0">
          <widget class="QLabel" name="thetaLabel">
           <property name="text">
            <string>Theta:</string>
           </property>
           <property name="toolTip">
            <string>Barnes-Hut approximation angle (0 = exact, higher = faster but less accurate)</string>
           </property>
          </widget>
         </item>
         <item row="2" column="1">
          <widget class="QDoubleSpinBox" name="thetaSpinBox">
           <property name="toolTip">
            <string>Barnes-Hut approximation parameter. 0 = exact t-SNE, 0.5 = good default for speed/accuracy trade-off.</string>
           </property>
           <property name="minimum">
            <double>0.000000000000000</double>
           </property>
           <property name="maximum">
            <double>1.000000000000000</double>
           </property>
           <property name="singleStep">
            <double>0.100000000000000</double>
           </property>
           <property name="decimals">
            <number>2</number>
           </property>
           <property name="value">
            <double>0.500000000000000</double>
           </property>
          </widget>
         </item>
        </layout>
       </widget>
      </item>
      <!-- Robust PCA parameters -->
      <item>
