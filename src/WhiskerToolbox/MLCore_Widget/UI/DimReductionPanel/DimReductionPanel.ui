         </item>
         <item row="1" column="1">
          <widget class="QDoubleSpinBox" name="rpcaLambdaSpinBox">
           <property name="toolTip">
            <string>Sparsity regularization. 0 = automatically set to 1/sqrt(max(m,n)). Higher values produce sparser error estimates.</string>
