         </item>
         <item row="2" column="0">
          <widget class="QLabel" name="rpcaMaxIterLabel">
           <property name="text">
            <string>Max iterations:</string>
           </property>
           <property name="toolTip">
            <string>Maximum number of ALM iterations</string>
